# Copy this file to .env and adjust values for your environment:
#   cp .env.example .env

# SECURITY WARNING: generate a fresh key for any real/shared deployment.
SECRET_KEY=change-me

# Set to False in production.
DEBUG=True

# Comma-separated list of allowed hosts. "*" allows all (dev only).
ALLOWED_HOSTS=*

# SQLite database file, relative to the backend/ directory.
DATABASE_PATH=data/db.sqlite3
